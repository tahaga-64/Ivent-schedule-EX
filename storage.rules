rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isEditor() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'google.com'
          && request.auth.token.email in [
            'taoki0183@gmail.com',
            'haruhito3901@gmail.com',
            'm.takada.kp@gmail.com'
          ];
    }

    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidFileSize() {
      return request.resource.size <= 10 * 1024 * 1024;
    }

    // イベント写真: events/{eventId}/{photoId}/{fileName}
    match /events/{eventId}/{photoId}/{fileName} {
      allow read: if isAuthenticated();
      allow create, update: if isEditor() && isImageFile() && isValidFileSize();
      allow delete: if isEditor();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
