rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 編集権限チェック: Google 認証済みユーザーのみ書き込み可
    // TODO(production): request.auth.uid in ['UID1','UID2',...] を追加して5名に限定すること
    function isEditor() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // preparationItems の ID フォーマット検証
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /events/{eventId} {
      allow read:  if true;
      allow write: if isEditor();

      match /preparationItems/{itemId} {
        allow read:  if true;
        allow write: if isEditor() && isValidId(itemId);
      }
    }
  }
}
