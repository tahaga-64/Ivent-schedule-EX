rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 読み取り：Googleログイン済みユーザー全員
    // イベント本体の書き込み：編集者数名のみ（クライアント canEditEvent と一致）
    function isEventEditor() {
      return request.auth != null
          && request.auth.token.email in [
               'taoki0183@gmail.com',
               'haruhito3901@gmail.com',
               'm.takada.kp@gmail.com',
             ];
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isEventEditor();

      // 準備物: ログイン済みユーザー全員が編集可（クライアント canEditPreparationList）
      match /preparationItems/{itemId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }
    }

    match /{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if isEventEditor();
    }
  }
}
