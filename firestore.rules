rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────────────────────────────────────
    // ログイン廃止モデル（2026-06-25〜）
    // アプリは起動時に自動で匿名サインインする。ログイン画面・管理者権限は無し。
    // 「匿名認証済み（＝アプリ利用者）なら全コレクションを読み書き可」とする。
    // 「誰が変更したか」はログインではなく、各ドキュメントに記録する自己申告の名前
    // （changedByName 等）で表現する（変更履歴機能）。
    //
    // 注意: APIキーはクライアントに公開されるため、これは「URL/キーを知る全員が
    // 読み書き可」に等しい。社内向けの割り切り。完全公開(if true)ではなく、
    // 最低限 Firebase 匿名認証を要求する。
    // ───────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
