rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // イベント本体の編集者（permissions.ts の EVENT_EDITOR_EMAILS と一致）
    function isEventEditor() {
      return request.auth != null
          && request.auth.token.email in [
               'taoki0183@gmail.com',
               'haruhito3901@gmail.com',
               'm.takada.kp@gmail.com',
             ];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEvent() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'venue', 'start', 'region', 'type'])
          && data.venue is string && data.venue.size() > 0 && data.venue.size() <= 500
          && data.region is string
          && data.type is string;
    }

    match /events/{eventId} {
      allow read:  if isAuthenticated();
      allow create: if isEventEditor() && isValidEvent();
      allow update: if isEventEditor();
      allow delete: if isEventEditor();

      // 準備物: ログイン済みユーザー全員が編集可（canEditPreparationList と一致）
      match /preparationItems/{itemId} {
        allow read:  if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && isValidId(itemId);
      }
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isEventEditor();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
