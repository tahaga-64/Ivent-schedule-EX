rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // イベント本体の編集者（permissions.ts の EVENT_EDITOR_EMAILS と一致）
    function isEventEditor() {
      return request.auth != null
          && request.auth.token.email in [
               'taoki0183@gmail.com',
               'haruhito3901@gmail.com',
               'm.takada.kp@gmail.com',
             ];
    }

    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'taoki0183@gmail.com';
    }

    // 魚リストの編集者（permissions.ts の FISH_LIST_EDITOR_EMAIL と一致）
    function isFishEditor() {
      return request.auth != null && request.auth.token.email == 'boruhirabayashi@icloud.com';
    }

    function isAdminUser() {
      return isSuperAdmin()
          || (isAuthenticated()
              && exists(/databases/$(database)/documents/userRoles/$(request.auth.token.email))
              && get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.role == 'admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEvent() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'venue', 'start', 'region', 'type'])
          && data.venue is string && data.venue.size() > 0 && data.venue.size() <= 500
          && data.region is string
          && data.type is string;
    }

    match /events/{eventId} {
      allow read:  if isAuthenticated();
      // isValidEvent() = フル作成, photos-only = 静的データのイベントへの写真追加（全員可）
      allow create: if (isEventEditor() && isValidEvent())
          || (isAuthenticated() && request.resource.data.keys().hasOnly(['photos']));
      // 写真のみの変更は全員可、それ以外は編集者のみ
      allow update: if isEventEditor()
          || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photos']));
      allow delete: if isEventEditor();

      // 準備物: ログイン済みユーザー全員が編集可（canEditPreparationList と一致）
      match /preparationItems/{itemId} {
        allow read:  if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && isValidId(itemId);
      }

      match /prepItems/{itemId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && isValidId(itemId);
      }
    }

    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEventEditor();
    }

    // 魚リスト: 読み取りは全員、書き込みは boruhirabayashi のみ（permissions.ts FISH_LIST_EDITOR_EMAIL と一致）
    match /events/{eventId}/fishItems/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isFishEditor();
    }

    // フロアレイアウト: 共有リンク(/?layout=ID)用に読み取りは公開。書き込みはログイン済みのみ。
    match /layouts/{layoutId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // 備品マスター（ログイン済みユーザー全員が編集可）
    match /masterItems/{itemId} {
      allow read, write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
          && request.auth.uid == userId
          && request.resource.data.uid == userId;

      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated()
            && request.resource.data.actorUid == request.auth.uid;
        allow update: if isAuthenticated()
            && request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isAuthenticated()
            && (request.auth.uid == userId || isEventEditor());
      }
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isEventEditor();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /userRoles/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }

    match /allowedUsers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();
    }

    // アプリ設定（静的DATA→Firestore 移行フラグ等）。編集者のみ書き込み可
    match /appConfig/{docId} {
      allow read: if isAuthenticated();
      allow write: if isEventEditor();
    }

    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
