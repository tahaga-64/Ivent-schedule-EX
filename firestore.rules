rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // イベント本体の編集者（permissions.ts の EVENT_EDITOR_EMAILS と一致）
    function isEventEditor() {
      return request.auth != null
          && request.auth.token.email in [
               'taoki0183@gmail.com',
               'haruhito3901@gmail.com',
               'm.takada.kp@gmail.com',
             ];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEvent() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'venue', 'start', 'region', 'type'])
          && data.venue is string && data.venue.size() > 0 && data.venue.size() <= 500
          && data.region is string
          && data.type is string;
    }

    /** メイン編集者以外が events ドキュメントを触れるのは、これらのトップレベルキーの変更のみ（UI の全員記入欄と一致） */
    function isCollaboratorOnlyEventFieldPatch() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'detailMemo',
            'detailMemoAttribution',
            'assigneeNote',
            'assigneeNoteAttribution',
            'note',
            'analysisReport',
            'client',
          ]);
    }

    match /events/{eventId} {
      allow read:  if isAuthenticated();
      allow create: if isEventEditor() && isValidEvent();
      allow update: if isEventEditor()
          || (isAuthenticated() && isCollaboratorOnlyEventFieldPatch());
      allow delete: if isEventEditor();

      // 準備物: ログイン済みユーザー全員が編集可（canEditPreparationList と一致）
      match /preparationItems/{itemId} {
        allow read:  if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && isValidId(itemId);
      }

      match /prepItems/{itemId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && isValidId(itemId);
      }
    }

    match /users/{userId} {
      allow get: if isAuthenticated()
          && (request.auth.uid == userId || isEventEditor());
      allow list: if isEventEditor();
      allow create, update: if isAuthenticated()
          && request.auth.uid == userId
          && request.resource.data.uid == userId;

      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isEventEditor();
        allow update: if isAuthenticated()
            && request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isAuthenticated()
            && (request.auth.uid == userId || isEventEditor());
      }
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isEventEditor();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
