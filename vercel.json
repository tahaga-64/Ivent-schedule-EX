{
  "crons": [{ "path": "/api/syncTracking", "schedule": "0 0 * * *" }],
  "rewrites": [
    { "source": "/((?!api/|push-sw\\.js|manifest\\.webmanifest|favicon\\.svg|icon|apple-touch-icon|mercury-).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/push-sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
