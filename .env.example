
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase configuration — copy values from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY="YOUR_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_DATABASE_ID="(default)"

# Web Push（FCM）— Firebase Console > Project settings > Cloud Messaging で
# 「Web Push certificates」のキーペアを生成し、公開鍵をここに設定（無料枠内で利用可）
VITE_FIREBASE_VAPID_KEY="YOUR_WEB_PUSH_PUBLIC_KEY"

# Supabase Storage configuration — used only for event photo files
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PHOTO_BUCKET="event-photos"
