
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase configuration — copy values from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY="YOUR_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_DATABASE_ID="(default)"

# Web Push（Cloudflare Worker 方式。FCM/Firebase Functions は不要）
# 1) npx web-push generate-vapid-keys --json で鍵ペアを生成
# 2) 公開鍵を下の VITE_WEB_PUSH_PUBLIC_KEY と workers/push/wrangler.toml に設定
# 3) 秘密鍵は wrangler secret put WEB_PUSH_PRIVATE_KEY で Worker のみに登録（コミット禁止）
# 4) Worker をデプロイし、出力された URL を VITE_PUSH_WORKER_URL に設定
# 詳細: docs/free-push-notifications.md
VITE_PUSH_WORKER_URL="https://ivent-schedule-push.YOUR_ACCOUNT.workers.dev"
VITE_WEB_PUSH_PUBLIC_KEY="YOUR_WEB_PUSH_PUBLIC_KEY"

# Firebase Admin SDK — サーバーサイド専用（api/ の関数で使用）
# Firebase Console > プロジェクト設定 > サービスアカウント > 新しい秘密鍵を生成
# ダウンロードしたJSONを1行に圧縮してVercelの環境変数に貼り付ける
# ★ クライアントには絶対に含めないこと（Vercelの環境変数のみで管理）
FIREBASE_SERVICE_ACCOUNT_JSON="{}"
